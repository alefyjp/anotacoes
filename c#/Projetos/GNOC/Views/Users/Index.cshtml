@model List<User>
@{
    ViewData["Title"] = "Usuários";
}
<!-- Submenu -->
<div class="row">
    <div class="col-md-1 col-sm-1">
        <button class="btn btn-sm btn-warning btn-100"><i class="fa-solid fa-plus"></i> Usuário</button>
    </div>
    <div class="col-md-12 col-sm-12">
        <br />
    </div>
</div>
<!-- Sectors table -->
<div class="row section">
    <div class="col-md-12 col-sm-12">
        <table class="table table-striped table-secondary table-sm">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Nome</th>
                    <th scope="col">E-mail</th>
                    <th scope="col">Setor</th>
                    <th scope="col">Status</th>
                    <th scope="col">Data cadastro</th>
                    <th scope="col">Perfil</th>
                    <th scope="col">Ação</th>
                </tr>
            </thead>
            <tbody>
                    @{
                        foreach (var u in Model)
                        {
                            <!--Tr exemple-->
                            <tr>
                                <td>@u.Id</td>
                                <td>@u.Name</td>
                                <td>@u.Email</td>
                                <td>@u.SectorId</td>
                                <td>@u.Status</td>
                                <td scope="col">@u.RegistrationDate</td>
                                <td scope="col">@u.Profile</td>
                                <td>
                                    <btn class="btn btn-warning btn-sm"><i class="fa-solid fa-eye"></i></btn>
                                </td>
                            </tr>
                        }
                    }
            </tbody>
        </table>
    </div>
</div>
