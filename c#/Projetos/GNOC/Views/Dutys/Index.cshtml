    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Plantões";
}
<!-- Submenu -->
<div class="row">
    <div class="col-md-1 col-sm-1">
        <button class="btn btn-sm btn-warning btn-100"><i class="fa-solid fa-plus"></i> Plantão</button>
    </div>
    <div class="col-md-2 col-sm-2">
        <form action="# method="post">
            <input type="text" class="form-control form-control-sm" placeholder="Colaborador" />
        </form>
    </div>
    <div class="col-md-2 col-sm-2">
        <form action="# method="post">
            <select class="form-select form-select-sm">
                <option>NOC</option>
            </select>
        </form>
    </div>
    <div class="col-md-2 col-sm-2">
        <form action="# method="post">
            <select class="form-select form-select-sm">
                <option>Novembro - 2025</option>
            </select>
        </form>
    </div>
    <div class="col-md-1 col-sm-1">
        <button class="btn btn-sm btn-warning btn-100" type="button">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
    </div>
    <div class="col-md-12 col-sm-12">
        <br />
    </div>
</div>
<!-- Sectors table -->
<div class="row section">
    <div class="col-md-12 col-sm-12">
        <table class="table table-striped table-secondary table-sm">
            <thead>
                <tr>
                    <th scope="col">Dia</th>
                    <th scope="col">Dia da semana</th>
                    <th scope="col">Colaborador</th>
                    <th scope="col">Escala</th>
                    <th scope="col">Descrição</th>
                    <th scope="col">Ação</th>
                </tr>
            </thead>
            <tbody>
                <!--Tr exemple-->
                <tr>
                    <td>1</td>
                    <td>Sábado</td>
                    <td>Teste</td>
                    <td>8h as 23h</td>
                    <td>Final de semana</td>
                    <td>
                        <btn class="btn btn-warning btn-sm"><i class="fa-solid fa-eye"></i></btn>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
