@{
    ViewData["Title"] = "Tarefas";
}
<!-- Submenu -->
<div class="row">
    <div class="col-md-1 col-sm-1">
        <button class="btn btn-sm btn-warning btn-100" onclick="openModal('create-modal')"><i class="fa-solid fa-plus"></i> Tarefa</button>
    </div>
    <div class="col-md-2 col-sm-2">
        <form action="# method="post">
            <input type="text" class="form-control form-control-sm" placeholder="Responsável" />
        </form>
    </div>
    <div class="col-md-2 col-sm-2">
        <form action="# method="post">
            <input type="date" class="form-control form-control-sm" placeholder="Data" />
        </form>
    </div>
    <div class="col-md-2 col-sm-2">
        <form action="# method="post">
            <select class="form-select form-select-sm">
                <option>NOC</option>
            </select>
        </form>
    </div>
    <div class="col-md-2 col-sm-2">
        <form action="# method="post">
            <select class="form-select form-select-sm">
                <option>Todas</option>
                <option>Pendentes</option>
                <option>Em execução</option>
                <option>Paralisadas</option>
                <option>Concluídas</option>
            </select>
        </form>
    </div>
    <div class="col-md-1 col-sm-1">
        <button class="btn btn-sm btn-warning btn-100" type="button">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
    </div>
    <div class="col-md-12 col-sm-12">
        <br />
    </div>
</div>
<!-- Tabela de tarefas -->
<div class="row section">
    <div class="col-md-12 col-sm-12">
        <table class="table table-striped table-secondary table-sm table-bordered ">
            <thead>
                <tr>
                    <th scope="col">Status</th>
                    <th scope="col">Titulo</th>
                    <th scope="col">Descrição</th>
                    <th scope="col">Comentário</th>
                    <th scope="col">Setor</th>
                    <th scope="col">Entrega</th>
                    <th scope="col">Prioridade</th>
                    <th scope="col">Solicitante</th>
                    <th scope="col">Responsável</th>
                    <th scope="col">Ação</th>
                </tr>
            </thead>
            <tbody id="tbUsers">
                <!-- Javascript-->
            </tbody>
        </table>
    </div>
</div>

<!--Modal Cadastro de tarefas -->
<div class="modal fade" id="create-modal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog modal-xl modal-dark">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title fs-5">
                    <i class="fa-solid fa-plus" aria-hidden="true"></i>
                     Nova tarefa
                </h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" onclick="closeModal('create-modal')"></button>
            </div>
            <div class="modal-body">
                <div class="container mt-5">
                    <div class="card shadow-sm p-4">
                        <form action="#" method="post" id="form-create-task" onsubmit="createTask(event)">
                            <div class="row g-3">
                                <div class="col-md-2">
                                    <label class="form-label">ID</label>
                                    <input type="text" class="form-control form-control-sm" readonly id="id-form-create">
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Status</label>
                                    <select class="form-select form-select-sm" id="status-form-create">
                                        <option selected disabled>Selecione...</option>
                                        <option>Aberto</option>
                                        <option>Em andamento</option>
                                        <option>Concluído</option>
                                        <option>Cancelado</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Título</label>
                                    <input type="text" class="form-control form-control-sm" placeholder="Digite o título" id="title-form-create">
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Descrição</label>
                                    <textarea class="form-control form-control-sm" rows="3" placeholder="Descreva a solicitação" id="description-form-create"></textarea>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Comentário</label>
                                    <textarea class="form-control form-control-sm" rows="2" placeholder="Comentários adicionais" id="comment-form-create"></textarea>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Setor</label>
                                    <input type="text" class="form-control form-control-sm" placeholder="Ex: TI, RH, Financeiro" id="sector-form-create">
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Entrega</label>
                                    <input type="date" class="form-control form-control-sm" id="delivery-form-create">
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label"><i class="fa-solid fa-radiation"></i>Prioridade</label>
                                    <select class="form-select form-select-sm" id="prioritylevel-form-create">
                                        <option selected disabled>Selecione...</option>
                                        <option>1</option>
                                        <option>2</option>
                                        <option>3</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Solicitante</label>
                                    <select class="form-select form-select-sm" id="requestername-form-create">
                                        <option selected disabled>Selecione...</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Responsável</label>
                                    <select class="form-select form-select-sm" id="agentname-form-create">
                                        <option selected disabled>Selecione...</option>
                                    </select>
                                </div>

                                <div class="col-4 mt-3">
                                    <button type="submit" class="btn btn-warning btn-100 btn-sm px-4" onlick="createTask()"><i class="fa-solid fa-floppy-disk"></i> Salvar</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Scripts desta página -->
<script src="~/js/tasks.js" asp-append-version="true"></script>